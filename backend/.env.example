# Backend Configuration
# Copy this file to .env for local development

# ============================================
# Server Configuration
# ============================================
PORT=13207
LOG_LEVEL=info
NODE_ENV=development

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
# Local development: use docker-compose postgres
DATABASE_URL=postgresql://nexus:nexussecret@localhost:5433/nexus

# Production: use server postgres
# DATABASE_URL=postgresql://nexus:NexusProd2024SecurePwd@localhost:5432/nexus

# ============================================
# Matrix Configuration
# ============================================
# Local development: use local matrix server
MATRIX_HOMESERVER_URL=http://localhost:8008
MATRIX_REGISTRATION_SECRET=dev-secret-change-in-production

# Production: use server matrix
# MATRIX_HOMESERVER_URL=http://8.217.143.228:8008
# MATRIX_REGISTRATION_SECRET=nexus_matrix_secret_xK9mP2vL7qR4wY6j

# ============================================
# Docker Configuration
# ============================================
# Default Docker socket path
DOCKER_HOST=/var/run/docker.sock

# For Podman (Linux):
# DOCKER_HOST=unix:///run/user/1000/podman/podman.sock

# ============================================
# AI Provider Configuration
# ============================================
OPENCODE_PROVIDER_NAME=tencent-coding-plan
OPENCODE_API_KEY=sk-sp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Legacy support (fallback if OPENCODE_API_KEY not set)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# Admin Configuration
# ============================================
ADMIN_PASSWORD=admin123

# ============================================
# OSS Configuration (JD Cloud)
# ============================================
OSS_ENDPOINT=https://s3.cn-east-1.jdcloud-oss.com
OSS_BUCKET=agent-resource
OSS_ACCESS_KEY_ID=JDC_921912A9F93626C555461C545917
OSS_ACCESS_KEY_SECRET=2E86CE84E4C36884E3E563AE2AE8924A