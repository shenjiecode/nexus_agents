# Dendrite Matrix Homeserver Configuration
# This file is a template - variables are replaced by start.sh from .env
# DO NOT edit this file directly - edit .env instead

version: 2

global:
  # Domain name of this homeserver (replaced from .env)
  server_name: ${MATRIX_SERVER_NAME}

  # Path to the signing private key (generated by Dendrite on first run)
  private_key: matrix_key.pem

  # PostgreSQL database connection (password replaced from .env)
  database:
    connection_string: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@matrix-postgres/${POSTGRES_DB}?sslmode=disable
    max_open_conns: 90
    max_idle_conns: 5
    conn_max_lifetime: -1

  # In-memory cache configuration
  cache:
    max_size_estimated: 1gb
    max_age: 1h

  # Federation control (replaced from .env)
  disable_federation: ${DISABLE_FEDERATION}

  # Presence configuration
  presence:
    enable_inbound: false
    enable_outbound: false

# Client API configuration
client_api:
  # Registration disabled - accounts created via shared secret API
  registration_disabled: true
  guests_disabled: true

  # Registration shared secret (replaced from .env)
  registration_shared_secret: "${REGISTRATION_SHARED_SECRET}"

  # reCAPTCHA disabled
  enable_registration_captcha: false
  recaptcha_public_key: ""
  recaptcha_private_key: ""

  # TURN server configuration (VoIP support)
  turn:
    turn_user_lifetime: "5m"
    turn_uris: []
    turn_shared_secret: ""

  # Rate limiting for API protection
  rate_limiting:
    enabled: true
    threshold: 20
    cooloff_ms: 500

# Federation API configuration
federation_api:
  # Federation status controlled by DISABLE_FEDERATION
  enabled: false
  servers: []

# Media API configuration
media_api:
  base_path: ./media_store
  max_file_size_bytes: 52428800  # 50MB
  dynamic_thumbnails: false

# Sync API configuration
sync_api:
  max_limit: 100
  max_timeout: 30000
  purge_history: true
  purge_age: 168h  # 7 days