# Matrix Server Configuration
# Copy this file to .env and update values for your environment

# ============================================
# Server Configuration (REQUIRED)
# ============================================
# Matrix server name - this is the domain/IP users see in their user ID
# Examples: matrix.example.com, 8.217.143.228
MATRIX_SERVER_NAME=8.217.143.228

# ============================================
# PostgreSQL Configuration
# ============================================
POSTGRES_USER=dendrite
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
POSTGRES_DB=dendrite
POSTGRES_PORT=5432

# ============================================
# Dendrite Ports
# ============================================
DENDRITE_HTTP_PORT=8008
DENDRITE_HTTPS_PORT=8448

# ============================================
# Element Web Port
# ============================================
ELEMENT_PORT=8080

# ============================================
# Registration Secret (REQUIRED)
# ============================================
# Used by Backend to register Matrix accounts programmatically
# Generate with: openssl rand -hex 32
REGISTRATION_SHARED_SECRET=CHANGE_ME_TO_RANDOM_STRING

# ============================================
# Federation (Optional)
# ============================================
# Set to "false" to disable federation (recommended for private deployment)
DISABLE_FEDERATION=true
