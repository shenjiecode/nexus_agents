# OpenCode Provider Configuration
# Provider name (default: tencent-coding-plan)
OPENCODE_PROVIDER_NAME=tencent-coding-plan

# API Key for the provider
OPENCODE_API_KEY=sk-sp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Legacy support (fallback if OPENCODE_API_KEY not set)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Matrix Configuration
# Matrix homeserver URL (required for employee account registration)
MATRIX_HOMESERVER_URL=http://localhost:8008

# Matrix Infrastructure
# To run a local Matrix homeserver for development:
# Run `cd matrix && ./init.ps1` to start Matrix server locally

# Business Database (PostgreSQL)
DATABASE_URL=postgresql://nexus:${POSTGRES_PASSWORD}@localhost:5433/nexus

# Matrix Registration Secret (must match dendrite.yaml)
MATRIX_REGISTRATION_SECRET=dev-secret-change-in-production
