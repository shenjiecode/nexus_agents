{
  "name": "nexus-agents",
  "version": "0.1.0",
  "private": true,
  "description": "Nexus Agents - Role Container Management System",
  "scripts": {
    "dev": "pnpm --filter @nexus/backend dev",
    "dev:backend": "pnpm --filter @nexus/backend dev",
    "dev:frontend": "pnpm --filter @nexus/frontend dev",
    "dev:all": "pnpm run --parallel '/^dev$/'",
    "build": "pnpm -r build",
    "build:backend": "pnpm --filter @nexus/backend build",
    "build:frontend": "pnpm --filter @nexus/frontend build"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
