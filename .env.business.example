# Business Stack Environment Variables
# Copy this file to .env.business and fill in your values

# PostgreSQL Password (shared between stacks)
POSTGRES_PASSWORD=nexussecret

# Matrix Homeserver URL (external - point to Matrix stack)
# For local development: http://localhost:8008
# For production: https://matrix.yourdomain.com
MATRIX_HOMESERVER_URL=http://localhost:8008

# Matrix Registration Secret (must match dendrite.yaml)
MATRIX_REGISTRATION_SECRET=dev-secret-change-in-production

# OpenCode Provider Configuration
OPENCODE_PROVIDER_NAME=tencent-coding-plan
OPENCODE_API_KEY=sk-sp-your-api-key-here

# Docker Host (for container management)
# Linux default: unix:///var/run/docker.sock
# Windows/Mac: use Docker Desktop socket
DOCKER_HOST=unix:///var/run/docker.sock